def selectionn(arr):
    n=len(arr)
    
    for i in range(n-1):
        min_ind=i 
    
        for j in range(i+1,n):
            if arr[min_ind]>arr[j]:
                min_ind=j
    
        arr[i],arr[min_ind] = arr[min_ind],arr[i]
        
    return arr
arr = [64, 25, 12, 22, 11]
print(selectionn(arr))
